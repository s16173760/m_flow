# Comma-separated list of allowed origins for CORS (leave empty to block all cross-origin requests)
# Example:
# CORS_ALLOWED_ORIGINS="https://yourdomain.com,https://another.com"
# For local development, you might use:
# CORS_ALLOWED_ORIGINS="http://localhost:3000"

# =============================================================================
# Prune API Configuration
# =============================================================================
# WARNING: The Prune API performs destructive, irreversible data deletion.
# These settings control administrative cleanup endpoints.

# Master switch for Prune API (default: false)
# Set to "true" to enable /api/v1/prune/* endpoints
# MFLOW_ENABLE_PRUNE_API=false

# Per-endpoint controls (default: true when API is enabled)
# MFLOW_PRUNE_ALLOW_ALL=true      # Allow /api/v1/prune/all
# MFLOW_PRUNE_ALLOW_DATA=true     # Allow /api/v1/prune/data
# MFLOW_PRUNE_ALLOW_SYSTEM=true   # Allow /api/v1/prune/system

# Minimum seconds between prune operations (default: 60)
# MFLOW_PRUNE_COOLDOWN_SECONDS=60

# Security Notes:
# - Prune API ALWAYS requires authentication, ignoring REQUIRE_AUTHENTICATION
# - Only superusers can execute prune operations
# - Each request requires explicit confirmation string