# =============================================================================
# M-FLOW ENVIRONMENT CONFIGURATION
# =============================================================================
#
# Quickstart: set MFLOW_LLM_API_KEY (or LLM_API_KEY for compat) and you're good to go.
# All variables support MFLOW_ prefix (preferred) with bare-name fallback.
# Defaults -- SQLite (relational), LanceDB (vector), Kuzu (graph).
# All defaults are file-based; no external services required for local dev.
# Data is stored in .venv by default.
#
# Service lifecycle (recommended):
#   ./scripts/manage_service.sh start | stop | restart | status
# Always use graceful shutdown to avoid database lock issues.
# On restart, stale locks are cleaned up automatically.
# =============================================================================


# =============================================================================
# RUNTIME
# =============================================================================

ENV="local"                                 # deployment environment tag
TOKENIZERS_PARALLELISM="false"              # avoid HuggingFace tokenizer fork warnings
LITELLM_LOG="ERROR"                         # LiteLLM log level (DEBUG, INFO, WARNING, ERROR)
# TELEMETRY_DISABLED=1                      # set to 1 to opt out of anonymous telemetry
# DEFAULT_USER_EMAIL=""                     # seed user email
# DEFAULT_USER_PASSWORD=""                  # seed user password


# =============================================================================
# ACCESS CONTROL
# =============================================================================

# --- environment mode ---
# Controls whether default secrets are allowed.
# Permissive: development | dev | local
# Strict (requires explicit secrets): production | staging | test
# MFLOW_ENV="production"

# --- JWT secrets (REQUIRED outside dev/local) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# FASTAPI_USERS_JWT_SECRET="your-secure-random-secret-here"
# FASTAPI_USERS_RESET_PASSWORD_TOKEN_SECRET="your-secure-random-secret-here"
# FASTAPI_USERS_VERIFICATION_TOKEN_SECRET="your-secure-random-secret-here"

REQUIRE_AUTHENTICATION=False                # set True to protect API with auth
ENABLE_BACKEND_ACCESS_CONTROL=True          # per-user+dataset DB isolation (SQLite, Postgres, LanceDB, KuzuDB)
ACCEPT_LOCAL_FILE_PATH=True                 # False when M-flow is a headless backend
ALLOW_HTTP_REQUESTS=True                    # False to block outbound HTTP (SSRF protection)
ALLOW_CYPHER_QUERY=True                     # False to disable raw Cypher queries
RAISE_INCREMENTAL_LOADING_ERRORS=True       # False to swallow errors on faulty documents


# =============================================================================
# LANGUAGE MODELS
# =============================================================================

STRUCTURED_OUTPUT_FRAMEWORK="instructor"    # instructor | baml

LLM_API_KEY="your_api_key"                  # REQUIRED -- your LLM provider API key
LLM_MODEL="openai/gpt-5-nano"              # model identifier (provider/model format)
LLM_PROVIDER="openai"                       # openai | ollama | custom
LLM_ENDPOINT=""                             # override base URL (leave blank for default)
LLM_API_VERSION=""                          # API version string (Azure, etc.)
LLM_MAX_TOKENS="16384"                      # max output tokens
LLM_INSTRUCTOR_MODE=""                      # override Instructor extraction mode (provider-specific defaults apply)

# --- Alternative LLM providers (M-flow exclusive) ---
# DeepSeek:  LLM_PROVIDER="custom"  LLM_MODEL="deepseek/deepseek-chat"  LLM_ENDPOINT="https://api.deepseek.com/v1"
# Qwen:      LLM_PROVIDER="custom"  LLM_MODEL="openai/qwen-plus"       LLM_ENDPOINT="https://dashscope.aliyuncs.com/compatible-mode/v1"
# Doubao:    LLM_PROVIDER="custom"  LLM_MODEL="openai/doubao-pro-256k"  LLM_ENDPOINT="https://ark.cn-beijing.volces.com/api/v3"
# Cohere:    LLM_PROVIDER="custom"  LLM_MODEL="cohere/command-r-plus"   LLM_ENDPOINT=""


# =============================================================================
# VECTOR EMBEDDINGS
# =============================================================================

EMBEDDING_PROVIDER="openai"                 # openai | ollama | custom
EMBEDDING_MODEL="openai/text-embedding-3-large"
EMBEDDING_ENDPOINT=""                       # override base URL
EMBEDDING_API_VERSION=""                    # API version string
EMBEDDING_DIMENSIONS=3072                   # output dimensionality
EMBEDDING_MAX_TOKENS=8191                   # max input tokens per chunk
EMBEDDING_BATCH_SIZE=36                     # requests per batch
# EMBEDDING_API_KEY="your_api_key"          # falls back to LLM_API_KEY if unset


# =============================================================================
# STRUCTURED OUTPUT (BAML)
# =============================================================================

BAML_LLM_PROVIDER=openai
BAML_LLM_MODEL="gpt-5-nano"
BAML_LLM_ENDPOINT=""
BAML_LLM_API_KEY="your_api_key"
BAML_LLM_API_VERSION=""


# =============================================================================
# STORAGE PATHS
# =============================================================================

# Override where M-flow stores data and system files.
# Useful for Docker volumes or avoiding .venv storage.
# DATA_ROOT_DIRECTORY='/Users/<user>/Desktop/m_flow/.m_flow_data/'
# SYSTEM_ROOT_DIRECTORY='/Users/<user>/Desktop/m_flow/.mflow/system/'

# --- S3 storage backend ---
# STORAGE_BACKEND="local"                   # local (default) | s3
# STORAGE_BUCKET_NAME="your-bucket-name"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# DATA_ROOT_DIRECTORY="s3://your-bucket/m_flow/data"
# SYSTEM_ROOT_DIRECTORY="s3://your-bucket/m_flow/system"
# CACHE_ROOT_DIRECTORY="s3://your-bucket/m_flow/cache"


# =============================================================================
# RELATIONAL DATABASE
# =============================================================================

DB_PROVIDER="sqlite"                        # sqlite | postgres
DB_NAME=mflow_store

# --- Postgres / PGVector ---
# DB_PROVIDER=postgres
# DB_NAME=mflow_store
# DB_HOST=127.0.0.1                         # use host.docker.internal inside Docker Compose
# DB_PORT=5432
# DB_USERNAME=m_flow
# DB_PASSWORD=m_flow


# =============================================================================
# VECTOR STORE
# =============================================================================

VECTOR_DB_PROVIDER="lancedb"                # pgvector | qdrant | weaviate | milvus | lancedb | chromadb
VECTOR_DB_URL=                              # required only for cloud/remote vector DBs
VECTOR_DB_KEY=                              # API key for cloud vector DBs
MFLOW_VECTOR_PARTITION_HANDLER="lancedb"   # multi-user dataset isolation handler

# --- Pinecone (M-flow exclusive) ---
# VECTOR_DB_PROVIDER="pinecone"
# PINECONE_API_KEY=""
# PINECONE_ENVIRONMENT="us-east-1"
# PINECONE_INDEX_NAME="m_flow"

# --- Milvus (M-flow exclusive) ---
# VECTOR_DB_PROVIDER="milvus"
# MILVUS_URI="http://localhost:19530"
# MILVUS_TOKEN=""


# =============================================================================
# GRAPH STORE
# =============================================================================

GRAPH_DATABASE_PROVIDER="kuzu"              # kuzu | kuzu-remote | neo4j
MFLOW_GRAPH_PARTITION_HANDLER="kuzu"       # multi-user dataset isolation handler

# --- Remote Kuzu ---
# GRAPH_DATABASE_PROVIDER="kuzu-remote"
# GRAPH_DATABASE_URL="http://localhost:8000"
# GRAPH_DATABASE_USERNAME=XXX
# GRAPH_DATABASE_PASSWORD=YYY

# --- Neo4j ---
