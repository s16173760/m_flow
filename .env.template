# GRAPH_DATABASE_URL=bolt://localhost:7687
# GRAPH_DATABASE_NAME="neo4j"
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=localneo4j


# =============================================================================
# ONTOLOGY RESOLVER
# =============================================================================

# ONTOLOGY_RESOLVER=rdflib                  # default resolver using OWL files
# MATCHING_STRATEGY=fuzzy                   # fuzzy matching at 80% similarity
# ONTOLOGY_FILE_PATH=YOUR_FULL_FILE_PATH   # absolute path to ontology file


# =============================================================================
# SCHEMA MIGRATIONS
# =============================================================================

MIGRATION_DB_PATH="/path/to/migration/directory"
MIGRATION_DB_NAME="migration_database.sqlite"
MIGRATION_DB_PROVIDER="sqlite"              # sqlite | postgres

# --- Postgres migration connection ---
# MIGRATION_DB_USERNAME=m_flow
# MIGRATION_DB_PASSWORD=m_flow
# MIGRATION_DB_HOST="127.0.0.1"
# MIGRATION_DB_PORT=5432


# =============================================================================
# CLOUD SYNC
# =============================================================================

MFLOW_CLOUD_API_URL="http://localhost:8001" # M-flow cloud backend endpoint
MFLOW_CLOUD_AUTH_TOKEN="your-api-key"       # API key for cloud sync


# =============================================================================
# WEB INTERFACE
# =============================================================================

UI_APP_URL=http://localhost:3000            # frontend URL


# =============================================================================
# AWS CREDENTIALS CREDENTIALS
# =============================================================================

# AWS_REGION=""
# AWS_ENDPOINT_URL=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_SESSION_TOKEN=""


# =============================================================================
# PIPELINE TUNING
# =============================================================================
#
# GRAPH_CONSTRUCTION_CONCURRENCY=4          # parallel workers for graph building
# RETRIEVAL_TOP_K=10                        # default top-K for vector search
