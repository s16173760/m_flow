# M-Flow Starter Kit — Environment Configuration
# Copy to .env and fill in your credentials.

# -- LLM Provider --------------------------------------------------------
LLM_API_KEY=""                           # Your OpenAI / Azure / Anthropic key
LLM_MODEL="openai/gpt-5-nano"           # Model identifier (litellm format)
LLM_PROVIDER="openai"                   # openai | azure | anthropic | ollama
LLM_ENDPOINT=""                         # Custom endpoint (leave blank for OpenAI)
LLM_API_VERSION=""                      # Required for Azure only

# -- Embedding Provider ---------------------------------------------------
EMBEDDING_API_KEY=""                     # Defaults to LLM_API_KEY if blank
EMBEDDING_MODEL="openai/text-embedding-3-large"
EMBEDDING_PROVIDER="openai"
EMBEDDING_ENDPOINT=""
EMBEDDING_API_VERSION=""
