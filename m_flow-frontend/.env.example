# M-Flow Frontend Environment Variables
# Copy this file to .env.local and configure the values

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (default: http://localhost:8000)
# Used for all REST API calls to the M-Flow backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (optional, defaults to API_URL with ws:// protocol)
# Used for real-time pipeline progress tracking
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# =============================================================================
# Authentication Settings
# =============================================================================

# Enable auto-login with default credentials (default: true)
# Set to 'false' in production to require manual login
# NEXT_PUBLIC_AUTO_LOGIN=true

# Default user credentials (should match backend base_config.py)
# These are used for auto-login and the "Use Default Account" button
# NEXT_PUBLIC_DEFAULT_USER_EMAIL=default_user@example.com
# NEXT_PUBLIC_DEFAULT_USER_PASSWORD=default_password

# =============================================================================
# Development Settings
# =============================================================================

# Enable debug mode for verbose logging (optional)
# NEXT_PUBLIC_DEBUG=false

# =============================================================================
# Production Deployment Notes
# =============================================================================
#
# For production deployments, ensure you:
# 1. Set NEXT_PUBLIC_AUTO_LOGIN=false to disable auto-login
# 2. Or set custom credentials that match your backend configuration
# 3. Never commit real credentials to version control
#
